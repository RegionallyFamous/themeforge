# Anthropic API key for LLM pipeline stages.
ANTHROPIC_API_KEY=

# Default model. Override per-stage in src/pipeline/config.ts.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Where finished theme bundles get written.
DEFAULT_OUTPUT_DIR=./output

# Optional: log directory for LLM request/response capture.
FORGE_LOG_DIR=./.forge-log
