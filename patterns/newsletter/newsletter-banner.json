{
  "id": "newsletter-banner",
  "name": "Newsletter — Banner",
  "category": "newsletter",
  "description": "Full-width signup banner. Centered heading + blurb above an inline email form. Uses the muted background-alt token to set itself apart from the surrounding sections.",

  "compatible_templates": ["index", "front-page", "page", "single-product", "archive-product"],
  "compatible_moods": ["editorial", "heritage", "nordic", "lux-mono", "apothecary", "botanical", "coastal", "playful", "sport"],

  "slots": {
    "heading": { "type": "text", "max_chars": 60,  "tone": "hero" },
    "blurb":   { "type": "text", "max_chars": 180, "tone": "supporting" }
  },

  "theme_tokens": [
    "color.background",
    "color.background-alt",
    "color.foreground",
    "color.primary",
    "typography.heading",
    "typography.body",
    "spacing.section"
  ],

  "tree": [
    {
      "name": "core/group",
      "attrs": {
        "align": "full",
        "tagName": "section",
        "backgroundColor": "background-alt",
        "style": { "spacing": { "padding": { "top": "var:preset|spacing|section", "bottom": "var:preset|spacing|section" } } },
        "layout": { "type": "constrained", "contentSize": "640px" }
      },
      "innerBlocks": [
        {
          "name": "core/heading",
          "attrs": { "level": 2, "textAlign": "center", "fontSize": "x-large" },
          "slot": "heading"
        },
        {
          "name": "core/paragraph",
          "attrs": { "align": "center" },
          "slot": "blurb"
        },
        {
          "name": "core/html",
          "content": "<form class=\"forge-newsletter forge-newsletter--banner\" method=\"post\" action=\"#\"><input type=\"email\" name=\"email\" placeholder=\"you@domain.com\" required><button type=\"submit\">Subscribe</button></form>"
        }
      ]
    }
  ]
}
