{
  "id": "hero-color-block",
  "name": "Hero — Color Block",
  "category": "hero",
  "description": "Massive single-color hero — the entire section is a brand-palette color, with oversized type centered against it. No image needed. Color does the work. Particularly effective for playful / sport / y2k / brutalist moods that should announce themselves loudly.",

  "compatible_templates": ["index", "front-page", "page"],
  "compatible_moods": ["playful", "sport", "y2k", "brutalist", "coastal", "editorial", "heritage"],

  "slots": {
    "eyebrow":   { "type": "text", "max_chars": 30,  "tone": "microcopy" },
    "headline":  { "type": "text", "max_chars": 90,  "tone": "hero" },
    "subhead":   { "type": "text", "max_chars": 200, "tone": "supporting" },
    "cta_label": { "type": "text", "max_chars": 24,  "tone": "cta" },
    "cta_url":   { "type": "url",  "default": "/shop" }
  },

  "theme_tokens": [
    "color.primary",
    "color.background",
    "color.foreground",
    "typography.heading",
    "spacing.section"
  ],

  "tree": [
    {
      "name": "core/group",
      "attrs": {
        "align": "full",
        "tagName": "section",
        "backgroundColor": "primary",
        "textColor": "background",
        "style": {
          "spacing": {
            "padding": {
              "top": "var:preset|spacing|section",
              "bottom": "var:preset|spacing|section",
              "left": "var:preset|spacing|40",
              "right": "var:preset|spacing|40"
            }
          },
          "dimensions": { "minHeight": "70vh" }
        },
        "layout": { "type": "constrained", "contentSize": "880px", "justifyContent": "center" }
      },
      "innerBlocks": [
        { "name": "core/paragraph", "attrs": { "fontSize": "small", "textColor": "background" }, "slot": "eyebrow" },
        { "name": "core/heading",   "attrs": { "level": 1, "fontSize": "huge", "textColor": "background", "style": { "typography": { "lineHeight": "0.95", "letterSpacing": "-0.02em" } } }, "slot": "headline" },
        { "name": "core/paragraph", "attrs": { "fontSize": "large", "textColor": "background" }, "slot": "subhead" },
        {
          "name": "core/buttons",
          "innerBlocks": [
            {
              "name": "core/button",
              "attrs": { "backgroundColor": "background", "textColor": "primary" },
              "slot": { "text": "cta_label", "url": "cta_url" }
            }
          ]
        }
      ]
    }
  ]
}
