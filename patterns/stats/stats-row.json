{
  "id": "stats-row",
  "name": "Stats — Number Row",
  "category": "stats",
  "description": "Three or four oversized numbers in a row, each with a small caption beneath. The 'we made X this year' / 'shipped Y orders' editorial moment that signals scale and pride. Big numbers, big tracking, small captions — leans on typographic contrast for impact.",

  "compatible_templates": ["index", "front-page", "page", "single-product"],
  "compatible_moods": ["editorial", "heritage", "lux-mono", "nordic", "sport", "sci", "playful", "coastal"],

  "slots": {
    "section_eyebrow": { "type": "text", "max_chars": 36, "tone": "microcopy" },

    "stat_1_number":  { "type": "text", "max_chars": 12, "tone": "hero" },
    "stat_1_caption": { "type": "text", "max_chars": 80, "tone": "microcopy" },

    "stat_2_number":  { "type": "text", "max_chars": 12, "tone": "hero" },
    "stat_2_caption": { "type": "text", "max_chars": 80, "tone": "microcopy" },

    "stat_3_number":  { "type": "text", "max_chars": 12, "tone": "hero" },
    "stat_3_caption": { "type": "text", "max_chars": 80, "tone": "microcopy" }
  },

  "theme_tokens": [
    "color.background",
    "color.foreground",
    "color.muted",
    "typography.heading",
    "spacing.section"
  ],

  "tree": [
    {
      "name": "core/group",
      "attrs": {
        "align": "full",
        "tagName": "section",
        "style": { "spacing": { "padding": { "top": "var:preset|spacing|section", "bottom": "var:preset|spacing|section" } } },
        "layout": { "type": "constrained" }
      },
      "innerBlocks": [
        {
          "name": "core/paragraph",
          "attrs": { "align": "center", "fontSize": "small", "textColor": "muted" },
          "slot": "section_eyebrow"
        },
        {
          "name": "core/columns",
          "gap": "blank",
          "attrs": { "align": "wide", "verticalAlignment": "top" },
          "innerBlocks": [
            {
              "name": "core/column",
              "innerBlocks": [
                { "name": "core/heading",   "attrs": { "level": 3, "textAlign": "center", "fontSize": "huge", "className": "has-stat-number-style" }, "slot": "stat_1_number" },
                { "name": "core/paragraph", "attrs": { "align": "center", "fontSize": "small", "textColor": "muted" }, "slot": "stat_1_caption" }
              ]
            },
            {
              "name": "core/column",
              "innerBlocks": [
                { "name": "core/heading",   "attrs": { "level": 3, "textAlign": "center", "fontSize": "huge", "className": "has-stat-number-style" }, "slot": "stat_2_number" },
                { "name": "core/paragraph", "attrs": { "align": "center", "fontSize": "small", "textColor": "muted" }, "slot": "stat_2_caption" }
              ]
            },
            {
              "name": "core/column",
              "innerBlocks": [
                { "name": "core/heading",   "attrs": { "level": 3, "textAlign": "center", "fontSize": "huge", "className": "has-stat-number-style" }, "slot": "stat_3_number" },
                { "name": "core/paragraph", "attrs": { "align": "center", "fontSize": "small", "textColor": "muted" }, "slot": "stat_3_caption" }
              ]
            }
          ]
        }
      ]
    }
  ]
}
