{
  "id": "testimonial-single",
  "name": "Testimonial — Single",
  "category": "testimonial",
  "description": "One large pull-quote with attribution. Centered, narrow column, generous padding so it reads as an editorial moment between heavier sections.",

  "compatible_templates": ["index", "front-page", "page", "single-product"],
  "compatible_moods": ["editorial", "heritage", "nordic", "lux-mono", "apothecary", "botanical", "coastal"],

  "slots": {
    "quote_text":  { "type": "text", "max_chars": 280, "tone": "hero" },
    "attribution": { "type": "text", "max_chars": 80,  "tone": "microcopy" }
  },

  "theme_tokens": [
    "color.background",
    "color.foreground",
    "color.muted",
    "typography.heading",
    "typography.body",
    "spacing.section"
  ],

  "tree": [
    {
      "name": "core/group",
      "attrs": {
        "align": "full",
        "tagName": "section",
        "style": { "spacing": { "padding": { "top": "var:preset|spacing|section", "bottom": "var:preset|spacing|section" } } },
        "layout": { "type": "constrained", "contentSize": "720px" }
      },
      "innerBlocks": [
        {
          "name": "core/paragraph",
          "attrs": { "align": "center", "fontSize": "x-large" },
          "slot": "quote_text"
        },
        {
          "name": "core/paragraph",
          "attrs": { "align": "center", "fontSize": "small", "textColor": "muted" },
          "slot": "attribution"
        }
      ]
    }
  ]
}
