{
  "id": "blog-grid",
  "name": "Blog — Three Up Grid",
  "category": "blog",
  "description": "Three-column post grid using core/query + core/post-template. Each card: featured image, title, date, excerpt. For homepages or dedicated blog index pages on stores that publish.",

  "compatible_templates": ["index", "front-page", "page"],
  "compatible_moods": ["editorial", "heritage", "nordic", "apothecary", "botanical", "coastal", "lux-mono"],

  "slots": {
    "section_eyebrow": { "type": "text", "max_chars": 30, "tone": "microcopy" },
    "section_heading": { "type": "text", "max_chars": 60, "tone": "hero" }
  },

  "theme_tokens": [
    "color.background",
    "color.foreground",
    "color.muted",
    "typography.heading",
    "typography.body",
    "spacing.section"
  ],

  "tree": [
    {
      "name": "core/group",
      "attrs": {
        "align": "full",
        "tagName": "section",
        "style": { "spacing": { "padding": { "top": "var:preset|spacing|section", "bottom": "var:preset|spacing|section" } } },
        "layout": { "type": "constrained" }
      },
      "innerBlocks": [
        {
          "name": "core/group",
          "attrs": { "layout": { "type": "constrained", "contentSize": "640px" } },
          "innerBlocks": [
            { "name": "core/paragraph", "attrs": { "fontSize": "small", "textColor": "muted" }, "slot": "section_eyebrow" },
            { "name": "core/heading",   "attrs": { "level": 2, "fontSize": "x-large" },         "slot": "section_heading" }
          ]
        },
        {
          "name": "core/query",
          "gap": "blank",
          "attrs": {
            "queryId": 5,
            "query": { "perPage": 3, "pages": 0, "offset": 0, "postType": "post", "order": "desc", "orderBy": "date" },
            "displayLayout": { "type": "flex", "columns": 3 },
            "align": "wide"
          },
          "innerBlocks": [
            {
              "name": "core/post-template",
              "innerBlocks": [
                { "name": "core/post-featured-image", "attrs": { "isLink": true, "aspectRatio": "16/9" } },
                { "name": "core/post-title",          "attrs": { "level": 3, "fontSize": "medium", "isLink": true } },
                { "name": "core/post-date",           "attrs": { "fontSize": "small", "textColor": "muted" } },
                { "name": "core/post-excerpt" }
              ]
            }
          ]
        }
      ]
    }
  ]
}
