{
  "id": "footer-minimal",
  "name": "Footer — Minimal",
  "category": "footer",
  "description": "Site title + a short link list on one line, copyright beneath a hairline separator. The lightest footer in the library — for stores whose footer chrome should disappear.",

  "compatible_templates": ["parts/footer"],
  "compatible_moods": ["editorial", "lux-mono", "nordic", "brutalist", "sci", "apothecary"],

  "slots": {
    "nav_links": {
      "type": "repeater",
      "min": 2,
      "max": 5,
      "items": {
        "label": { "type": "text", "max_chars": 30, "tone": "cta" },
        "url":   { "type": "url" }
      }
    },
    "copyright": { "type": "text", "max_chars": 80, "tone": "microcopy" }
  },

  "theme_tokens": [
    "color.background",
    "color.foreground",
    "color.muted",
    "typography.body",
    "spacing.40"
  ],

  "tree": [
    {
      "name": "core/group",
      "attrs": {
        "align": "full",
        "tagName": "footer",
        "style": { "spacing": { "padding": { "top": "var:preset|spacing|40", "bottom": "var:preset|spacing|40" } } },
        "layout": { "type": "constrained" }
      },
      "innerBlocks": [
        {
          "name": "core/group",
          "attrs": {
            "align": "wide",
            "layout": { "type": "flex", "justifyContent": "space-between", "verticalAlignment": "center" }
          },
          "innerBlocks": [
            { "name": "core/site-title", "attrs": { "level": 0, "fontSize": "small" } },
            { "name": "forge/link-list", "slot": "nav_links" }
          ]
        },
        {
          "name": "core/separator",
          "attrs": { "opacity": "css", "style": { "spacing": { "margin": { "top": "var:preset|spacing|30", "bottom": "var:preset|spacing|30" } } } }
        },
        {
          "name": "core/paragraph",
          "attrs": { "fontSize": "small", "textColor": "muted", "align": "center" },
          "slot": "copyright"
        }
      ]
    }
  ]
}
