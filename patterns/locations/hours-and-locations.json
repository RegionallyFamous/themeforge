{
  "id": "hours-and-locations",
  "name": "Locations — Hours & Address",
  "category": "locations",
  "description": "For stores with a brick-and-mortar component. Two columns: address + map embed left, opening hours right. Includes a microcopy line for special-hours notices (holidays, off-season).",

  "compatible_templates": ["page", "front-page"],
  "compatible_moods": ["heritage", "apothecary", "botanical", "coastal", "nordic", "playful"],

  "slots": {
    "section_heading":  { "type": "text", "max_chars": 60,  "tone": "hero" },
    "address":          { "type": "text", "max_chars": 200, "tone": "supporting" },
    "directions_url":   { "type": "url" },
    "directions_label": { "type": "text", "max_chars": 24,  "tone": "cta" },
    "hours":            { "type": "text", "max_chars": 320, "tone": "body" },
    "special_notice":   { "type": "text", "max_chars": 140, "tone": "microcopy" }
  },

  "theme_tokens": [
    "color.background",
    "color.foreground",
    "color.muted",
    "color.primary",
    "typography.heading",
    "typography.body",
    "spacing.section"
  ],

  "tree": [
    {
      "name": "core/group",
      "attrs": {
        "align": "full",
        "tagName": "section",
        "style": { "spacing": { "padding": { "top": "var:preset|spacing|section", "bottom": "var:preset|spacing|section" } } },
        "layout": { "type": "constrained" }
      },
      "innerBlocks": [
        { "name": "core/heading", "attrs": { "level": 2, "fontSize": "x-large" }, "slot": "section_heading" },
        {
          "name": "core/columns",
          "attrs": { "align": "wide", "verticalAlignment": "top" },
          "innerBlocks": [
            {
              "name": "core/column",
              "innerBlocks": [
                { "name": "core/heading",   "attrs": { "level": 3, "fontSize": "medium" }, "content": "Visit us" },
                { "name": "core/paragraph", "slot": "address" },
                {
                  "name": "core/buttons",
                  "innerBlocks": [
                    { "name": "core/button", "attrs": { "backgroundColor": "primary", "textColor": "background" }, "slot": { "text": "directions_label", "url": "directions_url" } }
                  ]
                }
              ]
            },
            {
              "name": "core/column",
              "innerBlocks": [
                { "name": "core/heading",   "attrs": { "level": 3, "fontSize": "medium" }, "content": "Hours" },
                { "name": "core/paragraph", "slot": "hours" },
                { "name": "core/paragraph", "attrs": { "fontSize": "small", "textColor": "muted" }, "slot": "special_notice" }
              ]
            }
          ]
        }
      ]
    }
  ]
}
