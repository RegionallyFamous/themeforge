{
  "id": "story-split",
  "name": "Story — Split (Image Bleed)",
  "category": "about",
  "description": "Asymmetric editorial story: large image takes 60% of the wide width and bleeds slightly past the constrained content; offset text column at 40% with eyebrow + headline + body + secondary CTA. The Outerknown / Saturdays NYC pattern — breaks the centered-stack rhythm of a homepage with a magazine moment.",

  "compatible_templates": ["index", "front-page", "page"],
  "compatible_moods": ["editorial", "heritage", "lux-mono", "apothecary", "botanical", "coastal", "nordic", "playful"],

  "slots": {
    "story_image":  { "type": "image_role", "role": "story_lifestyle_full", "aspect": "4:5" },
    "eyebrow":      { "type": "text", "max_chars": 36,  "tone": "microcopy" },
    "headline":     { "type": "text", "max_chars": 80,  "tone": "hero" },
    "body":         { "type": "text", "max_chars": 480, "tone": "body" },
    "cta_label":    { "type": "text", "max_chars": 28,  "tone": "cta" },
    "cta_url":      { "type": "url",  "default": "/about" }
  },

  "theme_tokens": [
    "color.background",
    "color.foreground",
    "color.muted",
    "color.primary",
    "typography.heading",
    "typography.body",
    "spacing.section"
  ],

  "tree": [
    {
      "name": "core/group",
      "attrs": {
        "align": "full",
        "tagName": "section",
        "style": { "spacing": { "padding": { "top": "var:preset|spacing|section", "bottom": "var:preset|spacing|section" } } },
        "layout": { "type": "constrained" }
      },
      "innerBlocks": [
        {
          "name": "core/columns",
          "attrs": { "align": "wide", "verticalAlignment": "center" },
          "innerBlocks": [
            {
              "name": "core/column",
              "attrs": { "width": "60%" },
              "innerBlocks": [
                { "name": "core/image", "attrs": { "sizeSlug": "large", "aspectRatio": "4/5" }, "slot": "story_image" }
              ]
            },
            {
              "name": "core/column",
              "attrs": { "width": "40%", "verticalAlignment": "center", "style": { "spacing": { "padding": { "left": "var:preset|spacing|40" } } } },
              "innerBlocks": [
                { "name": "core/paragraph", "attrs": { "fontSize": "small", "textColor": "muted" }, "slot": "eyebrow" },
                { "name": "core/heading",   "attrs": { "level": 2, "fontSize": "x-large", "style": { "typography": { "lineHeight": "1.05", "letterSpacing": "-0.02em" } } }, "slot": "headline" },
                { "name": "core/paragraph", "slot": "body" },
                {
                  "name": "core/buttons",
                  "innerBlocks": [
                    { "name": "core/button", "attrs": { "backgroundColor": "primary", "textColor": "background" }, "slot": { "text": "cta_label", "url": "cta_url" } }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
