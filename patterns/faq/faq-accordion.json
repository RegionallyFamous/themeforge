{
  "id": "faq-accordion",
  "name": "FAQ — Accordion",
  "category": "faq",
  "description": "Section heading above a stack of expand/collapse Q&A items rendered as native <details>. The item list is a single repeater slot — pattern customizers fill it once, the serializer expands it.",

  "compatible_templates": ["page", "single-product", "front-page"],
  "compatible_moods": ["editorial", "heritage", "nordic", "lux-mono", "apothecary", "botanical", "coastal", "sport", "sci"],

  "slots": {
    "section_heading": { "type": "text", "max_chars": 60, "tone": "hero" },
    "faqs": {
      "type": "repeater",
      "min": 3,
      "max": 10,
      "items": {
        "question": { "type": "text", "max_chars": 120, "tone": "supporting" },
        "answer":   { "type": "text", "max_chars": 480, "tone": "body" }
      }
    }
  },

  "theme_tokens": [
    "color.background",
    "color.foreground",
    "color.muted",
    "typography.heading",
    "typography.body",
    "spacing.section"
  ],

  "tree": [
    {
      "name": "core/group",
      "attrs": {
        "align": "full",
        "tagName": "section",
        "style": { "spacing": { "padding": { "top": "var:preset|spacing|section", "bottom": "var:preset|spacing|section" } } },
        "layout": { "type": "constrained", "contentSize": "720px" }
      },
      "innerBlocks": [
        {
          "name": "core/heading",
          "attrs": { "level": 2, "fontSize": "x-large" },
          "slot": "section_heading"
        },
        {
          "name": "forge/faq-list",
          "gap": "blank",
          "slot": "faqs"
        }
      ]
    }
  ]
}
