{
  "id": "faq-columns",
  "name": "FAQ — Two Columns",
  "category": "faq",
  "description": "Two side-by-side accordions, each fed by its own repeater of Q&A items. Useful when there are enough questions that a single column would feel like a wall of text.",

  "compatible_templates": ["page", "single-product", "front-page"],
  "compatible_moods": ["editorial", "heritage", "nordic", "lux-mono", "apothecary", "botanical", "coastal", "sport", "sci"],

  "slots": {
    "section_heading": { "type": "text", "max_chars": 60, "tone": "hero" },

    "faqs_left": {
      "type": "repeater",
      "min": 2,
      "max": 6,
      "items": {
        "question": { "type": "text", "max_chars": 120, "tone": "supporting" },
        "answer":   { "type": "text", "max_chars": 480, "tone": "body" }
      }
    },
    "faqs_right": {
      "type": "repeater",
      "min": 2,
      "max": 6,
      "items": {
        "question": { "type": "text", "max_chars": 120, "tone": "supporting" },
        "answer":   { "type": "text", "max_chars": 480, "tone": "body" }
      }
    }
  },

  "theme_tokens": [
    "color.background",
    "color.foreground",
    "color.muted",
    "typography.heading",
    "typography.body",
    "spacing.section"
  ],

  "tree": [
    {
      "name": "core/group",
      "attrs": {
        "align": "full",
        "tagName": "section",
        "style": { "spacing": { "padding": { "top": "var:preset|spacing|section", "bottom": "var:preset|spacing|section" } } },
        "layout": { "type": "constrained" }
      },
      "innerBlocks": [
        {
          "name": "core/heading",
          "attrs": { "level": 2, "fontSize": "x-large" },
          "slot": "section_heading"
        },
        {
          "name": "core/columns",
          "gap": "blank",
          "attrs": { "align": "wide" },
          "innerBlocks": [
            {
              "name": "core/column",
              "innerBlocks": [
                { "name": "forge/faq-list", "slot": "faqs_left" }
              ]
            },
            {
              "name": "core/column",
              "innerBlocks": [
                { "name": "forge/faq-list", "slot": "faqs_right" }
              ]
            }
          ]
        }
      ]
    }
  ]
}
