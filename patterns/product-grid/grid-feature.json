{
  "id": "grid-feature",
  "name": "Product Grid — Feature + Two",
  "category": "product-grid",
  "description": "One large featured product on the left, two smaller products stacked on the right. Useful for highlighting a hero SKU above a wider grid; works in editorial and heritage stores.",

  "compatible_templates": ["index", "front-page", "page"],
  "compatible_moods": ["editorial", "heritage", "lux-mono", "apothecary", "botanical"],

  "slots": {
    "section_eyebrow": { "type": "text", "max_chars": 30,  "tone": "microcopy" },
    "section_heading": { "type": "text", "max_chars": 60,  "tone": "hero" }
  },

  "theme_tokens": [
    "color.background",
    "color.foreground",
    "color.muted",
    "typography.heading",
    "typography.body",
    "spacing.section"
  ],

  "tree": [
    {
      "name": "core/group",
      "attrs": {
        "align": "full",
        "tagName": "section",
        "style": { "spacing": { "padding": { "top": "var:preset|spacing|section", "bottom": "var:preset|spacing|section" } } },
        "layout": { "type": "constrained" }
      },
      "innerBlocks": [
        {
          "name": "core/group",
          "attrs": { "layout": { "type": "constrained", "contentSize": "640px" } },
          "innerBlocks": [
            { "name": "core/paragraph", "attrs": { "fontSize": "small", "textColor": "muted" }, "slot": "section_eyebrow" },
            { "name": "core/heading",   "attrs": { "level": 2, "fontSize": "x-large" },         "slot": "section_heading" }
          ]
        },
        {
          "name": "woocommerce/product-collection",
          "gap": "blank",
          "attrs": {
            "queryId": 0,
            "displayLayout": { "type": "flex", "columns": 1, "shrinkColumns": false },
            "query": { "perPage": 1, "pages": 0, "offset": 0, "postType": "product", "order": "desc", "orderBy": "date" }
          },
          "innerBlocks": [
            {
              "name": "core/post-template",
              "innerBlocks": [
                { "name": "woocommerce/product-image", "attrs": { "imageSizing": "cropped", "aspectRatio": "16/9" } },
                { "name": "core/post-title",           "attrs": { "level": 3, "fontSize": "large", "isLink": true } },
                { "name": "woocommerce/product-price" }
              ]
            }
          ]
        },
        {
          "name": "woocommerce/product-collection",
          "gap": "blank",
          "attrs": {
            "queryId": 1,
            "displayLayout": { "type": "flex", "columns": 2, "shrinkColumns": true },
            "query": { "perPage": 2, "pages": 0, "offset": 1, "postType": "product", "order": "desc", "orderBy": "date" }
          },
          "innerBlocks": [
            {
              "name": "core/post-template",
              "innerBlocks": [
                { "name": "woocommerce/product-image", "attrs": { "imageSizing": "cropped", "aspectRatio": "1" } },
                { "name": "core/post-title",           "attrs": { "level": 3, "fontSize": "medium", "isLink": true } },
                { "name": "woocommerce/product-price" }
              ]
            }
          ]
        }
      ]
    }
  ]
}
