{
  "id": "grid-2up",
  "name": "Product Grid — Two Up",
  "category": "product-grid",
  "description": "Two featured products side by side. Larger product images than the 3-up grid; useful for stores with a small flagship range or for a 'staff picks' section above a wider grid.",

  "compatible_templates": ["index", "front-page", "archive-product", "page"],
  "compatible_moods": ["editorial", "heritage", "lux-mono", "apothecary", "botanical"],

  "slots": {
    "section_eyebrow": { "type": "text", "max_chars": 30,  "tone": "microcopy" },
    "section_heading": { "type": "text", "max_chars": 60,  "tone": "hero" },
    "section_blurb":   { "type": "text", "max_chars": 180, "tone": "supporting" }
  },

  "theme_tokens": [
    "color.background",
    "color.foreground",
    "color.muted",
    "typography.heading",
    "typography.body",
    "spacing.section"
  ],

  "tree": [
    {
      "name": "core/group",
      "attrs": {
        "align": "full",
        "tagName": "section",
        "style": { "spacing": { "padding": { "top": "var:preset|spacing|section", "bottom": "var:preset|spacing|section" } } },
        "layout": { "type": "constrained" }
      },
      "innerBlocks": [
        {
          "name": "core/group",
          "attrs": { "layout": { "type": "constrained", "contentSize": "640px" } },
          "innerBlocks": [
            { "name": "core/paragraph", "attrs": { "fontSize": "small", "textColor": "muted" }, "slot": "section_eyebrow" },
            { "name": "core/heading",   "attrs": { "level": 2, "fontSize": "x-large" },         "slot": "section_heading" },
            { "name": "core/paragraph", "slot": "section_blurb" }
          ]
        },
        {
          "name": "woocommerce/product-collection",
          "gap": "blank",
          "attrs": {
            "queryId": 0,
            "query": {
              "perPage": 2, "pages": 0, "offset": 0, "postType": "product", "order": "desc", "orderBy": "date",
              "search": "", "exclude": [], "inherit": false, "taxQuery": {},
              "isProductCollectionBlock": true, "woocommerceOnSale": false,
              "woocommerceStockStatus": ["instock", "outofstock", "onbackorder"],
              "woocommerceAttributes": [], "woocommerceHandPickedProducts": []
            },
            "tagName": "div",
            "dimensions": { "widthType": "fill", "fixedWidth": "" },
            "displayLayout": { "type": "flex", "columns": 2 },
            "align": "wide"
          },
          "innerBlocks": [
            {
              "name": "woocommerce/product-template",
              "innerBlocks": [
                {
                  "name": "woocommerce/product-image",
                  "attrs": { "showSaleBadge": true, "aspectRatio": "4/5", "imageSizing": "thumbnail", "isDescendentOfQueryLoop": true },
                  "innerBlocks": [
                    { "name": "woocommerce/product-sale-badge", "attrs": { "isDescendentOfQueryLoop": true, "align": "right" } }
                  ]
                },
                { "name": "core/post-title", "attrs": { "level": 3, "isLink": true, "fontSize": "large", "__woocommerceNamespace": "woocommerce/product-collection/product-title" } },
                { "name": "woocommerce/product-price", "attrs": { "isDescendentOfQueryLoop": true, "fontSize": "medium" } }
              ]
            }
          ]
        }
      ]
    }
  ]
}
