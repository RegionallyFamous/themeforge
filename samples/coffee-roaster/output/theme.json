{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "720px",
      "wideSize": "1240px"
    },
    "color": {
      "palette": [
        { "name": "Background",     "slug": "background",     "color": "#F6F1EA" },
        { "name": "Background Alt", "slug": "background-alt", "color": "#E8D9C2" },
        { "name": "Foreground",     "slug": "foreground",     "color": "#2E1F14" },
        { "name": "Muted",          "slug": "muted",          "color": "#7A6757" },
        { "name": "Primary",        "slug": "primary",        "color": "#A8531E" },
        { "name": "Accent",         "slug": "accent",         "color": "#1A1A1A" }
      ],
      "custom": false,
      "defaultPalette": false,
      "defaultGradients": false
    },
    "typography": {
      "fontFamilies": [
        {
          "name": "Fraunces",
          "slug": "heading",
          "fontFamily": "Fraunces, 'Iowan Old Style', 'Apple Garamond', 'Times New Roman', serif"
        },
        {
          "name": "Inter",
          "slug": "body",
          "fontFamily": "Inter, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif"
        }
      ],
      "fontSizes": [
        { "slug": "small",   "size": "0.9rem",         "name": "Small",   "fluid": false },
        { "slug": "medium",  "size": "1.0625rem",      "name": "Medium",  "fluid": false },
        { "slug": "large",   "size": "clamp(1.25rem, 1.1rem + 0.6vw, 1.5rem)",  "name": "Large" },
        { "slug": "x-large", "size": "clamp(1.75rem, 1.4rem + 1.4vw, 2.25rem)", "name": "X-Large" },
        { "slug": "huge",    "size": "clamp(2.5rem, 1.8rem + 3vw, 4rem)",       "name": "Huge" }
      ],
      "fluid": true,
      "lineHeight": true,
      "letterSpacing": true
    },
    "spacing": {
      "spacingScale": { "operator": "*", "increment": 1.5, "steps": 7, "mediumStep": 1.5, "unit": "rem" },
      "spacingSizes": [
        { "name": "Tight",   "slug": "20", "size": "0.75rem" },
        { "name": "Snug",    "slug": "30", "size": "1.25rem" },
        { "name": "Cozy",    "slug": "40", "size": "2rem" },
        { "name": "Roomy",   "slug": "50", "size": "3.25rem" },
        { "name": "Section", "slug": "section", "size": "clamp(4rem, 3rem + 4vw, 6.5rem)" }
      ],
      "units": ["px", "em", "rem", "%", "vh", "vw"]
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text":       "var(--wp--preset--color--foreground)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize":   "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.6"
    },
    "spacing": {
      "blockGap": "1.25rem"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily":     "var(--wp--preset--font-family--heading)",
          "fontSize":       "var(--wp--preset--font-size--huge)",
          "fontWeight":     "500",
          "lineHeight":     "1.05",
          "letterSpacing":  "-0.02em"
        }
      },
      "h2": {
        "typography": {
          "fontFamily":     "var(--wp--preset--font-family--heading)",
          "fontSize":       "var(--wp--preset--font-size--x-large)",
          "fontWeight":     "500",
          "lineHeight":     "1.1",
          "letterSpacing":  "-0.015em"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize":   "var(--wp--preset--font-size--large)",
          "fontWeight": "500",
          "lineHeight": "1.2"
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text":       "var(--wp--preset--color--background)"
        },
        "typography": { "fontWeight": "500", "letterSpacing": "0.02em" },
        "border":     { "radius": "0px" },
        "spacing":    { "padding": { "top": "0.85rem", "bottom": "0.85rem", "left": "1.5rem", "right": "1.5rem" } }
      },
      "link": {
        "color":      { "text": "var(--wp--preset--color--foreground)" },
        "typography": { "textDecoration": "underline" }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ],
  "customTemplates": [
    { "name": "page-no-title", "title": "Page (no title)", "postTypes": ["page"] }
  ]
}
